FROM python:3.11-slim

WORKDIR /app

COPY backend/pyproject.toml backend/.env ./
RUN pip install uv && uv sync --no-dev

COPY backend/ .

RUN mkdir -p /data
ENV DATABASE_URL=sqlite+aiosqlite:////data/flowy.db

EXPOSE 8000
CMD ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
