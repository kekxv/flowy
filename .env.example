# App
APP_NAME=Flowy
APP_SECRET_KEY=dev-secret-change-in-production

# JWT secret used for signing authentication tokens.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=dev-jwt-secret-change-in-production

# Encryption key for sensitive data at rest (e.g., OAuth tokens).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=

# Server
PORT=80
LOG_LEVEL=info

# CORS — comma-separated list of allowed origins (protocol + domain + port).
# In production, list your frontend origin(s) explicitly:
#   CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:3000

# Frontend URL — used for OAuth callbacks and link generation.
# Must match the actual deployed frontend URL in production.
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=sqlite+aiosqlite:///./flowy.db

# OAuth (optional)
# Steps to enable an OAuth provider:
#   1. Register a new OAuth app on the provider's developer console.
#   2. Set the callback / redirect URL to:
#      http://<your-domain>/api/v1/auth/<provider>/oauth/callback
#      (e.g., http://localhost:8000/api/v1/auth/github/oauth/callback)
#   3. Copy the Client ID and Client Secret into the variables below.
#   4. Restart the application.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITEA_CLIENT_ID=
GITEA_CLIENT_SECRET=

# Sync
SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=5
